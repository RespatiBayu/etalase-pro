NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Override model names if Google renames/deprecates them
# Check: https://ai.google.dev/gemini-api/docs/models
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_API_VERSION=v1beta

# fal.ai — used for paid image generation (generate-image, latar-ai)
FAL_KEY=
# Image generation model (generate-image + latar-ai)
FAL_IMAGE_MODEL=fal-ai/nano-banana/edit

# Background removal: berjalan 100% di browser user pakai
# @imgly/background-removal (onnxruntime-web + ONNX model dari CDN imgly).
# Tidak perlu API key. Tidak makan kuota Vercel. Gratis selamanya.

SCALEV_SIGNING_SECRET=
SCALEV_API_KEY=
NEXT_PUBLIC_APP_URL=https://etalase-pro.vercel.app
